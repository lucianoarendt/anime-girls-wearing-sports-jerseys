{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "character", "anime", "team", "sport", "year", "image", "tags"],
  "properties": {
    "id": { "type": "string" },
    "character": { "type": "string" },
    "anime": { "type": "string" },
    "team": { "type": "string" },
    "sport": { "type": "string" },
    "year": { "type": "integer" },
    "image": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
